{
    "name": "antigravity-remote-control",
    "displayName": "Antigravity Remote Control",
    "description": "Telegram Remote Control Bridge for Antigravity (CDP Native + Image Support)",
    "version": "0.2.5",
    "publisher": "YashMahawar",
    "license": "MIT",
    "engines": {
        "vscode": "^1.70.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/YashMahawa/antigravity-remote-control.git"
    },
    "icon": "icon.png",
    "categories": [
        "Programming Languages",
        "Keymaps"
    ],
    "activationEvents": [
        "*"
    ],
    "main": "./extension.js",
    "contributes": {
        "commands": [
            {
                "command": "telegram-bridge.setBotToken",
                "title": "Telegram Bridge: Set Bot Token"
            },
            {
                "command": "telegram-bridge.setChatId",
                "title": "Telegram Bridge: Set Chat ID"
            }
        ],
        "configuration": {
            "title": "Antigravity Telegram Bridge",
            "properties": {
                "antigravityTelegram.botToken": {
                    "type": "string",
                    "default": "",
                    "description": "The Telegram Bot Token from @BotFather"
                },
                "antigravityTelegram.chatId": {
                    "type": "string",
                    "default": "",
                    "description": "The Telegram Chat ID to send messages to"
                }
            }
        }
    },
    "dependencies": {
        "dotenv": "^17.3.1",
        "telegraf": "^4.16.3",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/node": "^16.11.7",
        "@types/vscode": "^1.70.0"
    }
}